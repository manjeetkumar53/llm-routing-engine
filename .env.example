# LLM provider: mock | openai | ollama | anthropic (default: mock)
LLM_PROVIDER=mock

# API keys (only required for the selected provider)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama model overrides (optional — defaults to llama3.2:1b / llama3.1:8b)
# OLLAMA_BASE_URL=http://localhost:11434/api/chat
# OLLAMA_CHEAP_MODEL=llama3.2:1b
# OLLAMA_PREMIUM_MODEL=llama3.1:8b

# Route to premium when complexity score is greater than this threshold
ROUTER_COMPLEXITY_THRESHOLD=0.50

# Estimated input/output token price in USD per 1M tokens
CHEAP_INPUT_PRICE_PER_1M=0.15
CHEAP_OUTPUT_PRICE_PER_1M=0.60
PREMIUM_INPUT_PRICE_PER_1M=5.00
PREMIUM_OUTPUT_PRICE_PER_1M=15.00
